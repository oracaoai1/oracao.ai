# Copie este arquivo para ".env.local" e preencha com suas chaves.

# Anthropic — obtenha em https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Supabase — crie um projeto em https://supabase.com/dashboard
# e copie os valores em Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Chave service_role: SECRETA, apenas no servidor. Nunca exponha no cliente.
SUPABASE_SERVICE_ROLE_KEY=
