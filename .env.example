# Copie este arquivo para ".env.local" e preencha com suas chaves.

# Anthropic — obtenha em https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...
# Modelo das conversas (opcional). Padrão: claude-haiku-4-5-20251001.
# Alternativa mais capaz: claude-opus-4-8
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Supabase — crie um projeto em https://supabase.com/dashboard
# e copie os valores em Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Chave service_role: SECRETA, apenas no servidor. Nunca exponha no cliente.
SUPABASE_SERVICE_ROLE_KEY=

# Limites diarios (free tier / protecao de custo)
CHAT_DAILY_LIMIT=50
AUDIO_DAILY_LIMIT=20
CHAT_MAX_MESSAGE_CHARS=2000
